# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=darkvision-postgres
POSTGRES_PORT=5432
POSTGRES_DB=darkvision
POSTGRES_USER=darkvision
POSTGRES_PASSWORD=CHANGE_ME_strong_db_pass

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=darkvision-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_pass

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_64_chars_random_secret_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── App ──────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
LOG_LEVEL=info
ALLOWED_ORIGINS=https://panel.yourdomain.com

# ── Xray ─────────────────────────────────────────────────
XRAY_CONFIG_PATH=/xray-config/config.json
XRAY_API_HOST=darkvision-xray
XRAY_API_PORT=10085

# ── Панель ───────────────────────────────────────────────
PANEL_PORT=9443
PANEL_HTTP_PORT=9080
PANEL_DOMAIN=panel.yourdomain.com

# ── Подписки (можно задать CDN домен) ────────────────────
# Итоговые ссылки: https://cdn.wedarkvpn.org/TOKEN
SUB_BASE_URL=https://cdn.yourdomain.com

# ── VPN (не конфликтует с remnawave на 443) ───────────────
VLESS_PORT=2053

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

ADMIN_SETUP_DONE=false
